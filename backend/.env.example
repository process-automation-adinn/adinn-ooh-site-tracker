# Neon PostgreSQL connection string.
# Copy this from Neon Dashboard > Connect > Connection string.
# Keep sslmode=require in the URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

OOH_SECRET_KEY=change-this-secret-before-production

# For deployment, add your hosted frontend domain here.
# Example: CORS_ORIGINS=https://ooh.adinn.com,https://www.ooh.adinn.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# First admin account created automatically when the users table is empty.
# Change these before deploying publicly.
SEED_ADMIN_NAME=ADINN Admin
SEED_ADMIN_EMAIL=admin@adinn.com
SEED_ADMIN_PASSWORD=Admin@123

# For production, set this to false and create employees from the Admin > Employees page.
CREATE_DEMO_EMPLOYEE=true
DEMO_EMPLOYEE_NAME=Field Employee
DEMO_EMPLOYEE_EMAIL=employee@adinn.com
DEMO_EMPLOYEE_PASSWORD=Employee@123

# Local/project uploads folder. On Render with Persistent Disk, set this to /var/data/uploads.
UPLOAD_DIR=
